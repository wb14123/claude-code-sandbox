#!/bin/sh

set -e

docker run -it \
  -v ~/.claude:/home/node/.claude \
  -v ~/.claude.json:/home/node/.claude.json \
  -v ~/.cargo:/home/node/.cargo \
  -v "$(pwd)":"$(pwd)" \
  -w "$(pwd)" \
  -u "$(id -u):$(id -g)" \
  -e CARGO_TARGET_DIR=./target-docker \
  --entrypoint /usr/local/bin/claude \
  wb14123/claude-code:latest \
  "$@"
